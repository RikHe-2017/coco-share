{
  "name": "@coco-share/workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "pnpm -r run build",
    "test": "pnpm run build && vitest run",
    "test:coverage": "pnpm run build && vitest run --coverage",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo",
    "changeset": "changeset",
    "bump": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.21.0",
    "fflate": "^0.8.2",
    "shx": "^0.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.1.9"
  }
}
